DATABASE_URL=postgresql://user:password@localhost:5432/gastar
PORT=3000
NODE_ENV=development

# Set to 'true' in single-container production deployments.
# When enabled, Express serves the compiled frontend from FRONTEND_DIST_PATH.
# CORS_ORIGIN becomes optional (same-origin requests don't need it).
# SERVE_FRONTEND=true
# FRONTEND_DIST_PATH=/app/frontend/dist  # optional — defaults to packages/frontend/dist
